      "source": [
        "from torch.nn import Embedding, LSTM, Linear, Module, CrossEntropyLoss, Dropout\n",
        "from torch import optim\n",
        "\n",
        "class GeneratorLSTM(Module):\n",
        "  def __init__(self, vocab_size, embed_size=128, hidden_size=256, num_layers=2):\n",
        "    super().__init__()\n",
        "    self.embedding=Embedding(vocab_size,embed_size)\n",
        "    self.lstm=LSTM(embed_size, hidden_size, batch_first=True, dropout=0.1)\n",
        "    self.dropout=Dropout(0.1)\n",
        "    self.fc=Linear(hidden_size, vocab_size) # на каждое слово вероятность\n",
        "\n",
        "  def forward(self,x):\n",
        "    x=self.embedding(x)\n",
        "    output=self.lstm(x)[0]\n",
        "    last_output=output[:,-1,:]\n",
        "    last_output=self.dropout(last_output)\n",
        "    x=self.fc(last_output)\n",
        "    return x\n",
        "\n",
        "device=torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "\n",
        "vocab_size=len(tokenizer.word_index)+1\n",
        "model=GeneratorLSTM(vocab_size).to(device)\n",
        "loss_f=CrossEntropyLoss()\n",
        "optimizer=optim.Adam(model.parameters(), lr=0.001, weight_decay=1e-5)"
      ],
      "metadata": {
        "id": "hjBYjyxsLZ6P"
      },
      "execution_count": null,
      "outputs": []
